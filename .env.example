# ─── AI Provider ─────────────────────────────────────────────────────────────
GEMINI_API_TOKEN=your-google-ai-studio-api-key

# ─── GitHub ──────────────────────────────────────────────────────────────────
# PAT needs: repo, issues:write, pull_requests:write
GH_TOKEN=your-github-personal-access-token
GITHUB_OWNER=cairocoder01

# ─── Issue Lifecycle Labels ───────────────────────────────────────────────────
# Issues with TRIGGER_LABEL are picked up by the worker
TRIGGER_LABEL=dt-agent-build
# Applied immediately when the worker claims an issue (prevents double-pickup across container runs)
PROCESSING_LABEL=dt-agent-processing
# Applied when agent needs human clarification before continuing
WAITING_LABEL=dt-agent-waiting-for-human
# Applied when all verify stages pass and a PR has been opened
READY_LABEL=ready-for-human-review

# ─── Loop Control ─────────────────────────────────────────────────────────────
# Maximum number of execute→verify iterations before giving up
MAX_LOOP_RETRIES=5
# Seconds before opencode is killed and the run is marked BLOCKED (0 = no timeout)
AGENT_TIMEOUT=1800
# Set to true to run all stages without any GitHub writes (push, PR, label mutations).
# Useful for local testing. See tests/run_stage.sh for per-stage development.
DRY_RUN=false
# Seconds to sleep between polls when no issues are found.
# This is the effective cron interval: the worker sleeps this long when idle,
# then Docker restarts it. When work is found it runs immediately (no sleep).
IDLE_SLEEP=900

# ─── WordPress Test Database ─────────────────────────────────────────────────
# When using docker-compose.yml, WP_DB_HOST is set automatically to "mysql" (the
# linked service) and does not need to be set here. Override only if running the
# worker against an external MySQL instance.
# WP_DB_HOST=host.docker.internal
WP_DB_NAME=wordpress_test
WP_DB_USER=wp
WP_DB_PASS=wp
# Root password for the mysql service (docker-compose only)
MYSQL_ROOT_PASSWORD=rootpass

# ─── Optional Overrides ───────────────────────────────────────────────────────
# WordPress version to install for testing
WP_VERSION=latest

# Branch that PRs should target (auto-detected from remote if blank: develop → main → master)
BASE_BRANCH=

# opencode model in provider/model format
# Other examples: google/gemini-1.5-pro, anthropic/claude-3-5-sonnet-20241022
OPENCODE_MODEL=google/gemini-3-flash-preview

# ─── Base WordPress Theme ─────────────────────────────────────────────────────
# Bootstrap hook (03_install_base_theme.sh) installs the latest release of this
# theme into the WordPress test install. Override if you maintain a fork.
# When TARGET_REPO matches this theme, the agent's own changes are used instead.
DT_BASE_THEME_REPO=DiscipleTools/disciple-tools-theme

# ─── E2E Verification ────────────────────────────────────────────────────────
# 02b_prep_e2e_site.sh starts a PHP built-in server inside the worker container
# and serves the WordPress test install at this URL before 03_chrome_mcp_e2e.js runs.
# Change WP_E2E_PORT if 8080 conflicts with something on your host.
WP_TEST_URL=http://localhost:8080
WP_E2E_PORT=8080

# ─── WordPress Options Injection ─────────────────────────────────────────────
# Path INSIDE the container to a KEY=VALUE file written to wp_options before each issue.
# To use: create your secrets file, add a volume mount in docker-compose.yml pointing
# the host file to /run/secrets/wp-options, then set this to /run/secrets/wp-options.
# Each line: OPTION_NAME=value  (lines starting with # are ignored)
WP_OPTIONS_FILE=
