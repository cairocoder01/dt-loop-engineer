# ─── AI Provider ─────────────────────────────────────────────────────────────
GEMINI_API_TOKEN=your-google-ai-studio-api-key

# ─── GitHub ──────────────────────────────────────────────────────────────────
# PAT needs: repo, issues:write, pull_requests:write
GH_TOKEN=your-github-personal-access-token
GITHUB_OWNER=cairocoder01

# ─── Issue Lifecycle Labels ───────────────────────────────────────────────────
# Issues with TRIGGER_LABEL are picked up by the worker
TRIGGER_LABEL=dt-agent-build
# Applied when agent needs human clarification before continuing
WAITING_LABEL=dt-agent-waiting-for-human
# Applied when all verify stages pass and a PR has been opened
READY_LABEL=ready-for-human-review

# ─── Loop Control ─────────────────────────────────────────────────────────────
# Maximum number of execute→verify iterations before giving up
MAX_LOOP_RETRIES=5

# ─── WordPress Test Database ─────────────────────────────────────────────────
WP_DB_HOST=host.docker.internal
WP_DB_NAME=wordpress_test
WP_DB_USER=root
WP_DB_PASS=

# ─── Optional Overrides ───────────────────────────────────────────────────────
# WordPress version to install for testing (default: latest)
# WP_VERSION=latest

# Branch that PRs should target (default: develop)
# BASE_BRANCH=develop

# opencode model override (default: gemini)
# OPENCODE_MODEL=gemini
